<script>
// ─── STATE ───────────────────────────────────────────────────────────
let state = {
  sessions: [],
  clockInTime: null,
  settings: {
    hourlyRate: 18, otMult: 1.5, otAfter: 40,
    payFreq: 'biweekly', filing: 'single',
    stateTax: 4.40, denverOPT: 5.75
  }
};

// ─── STORAGE ─────────────────────────────────────────────────────────
function save() {
  try { localStorage.setItem('hs_state', JSON.stringify({sessions:state.sessions, settings:state.settings})); } catch(e){}
}
function load() {
  try {
    const d = JSON.parse(localStorage.getItem('hs_state')||'{}');
    if(d.sessions) state.sessions = d.sessions.map(s=>({...s,date:new Date(s.date),start:new Date(s.start),end:new Date(s.end)}));
    if(d.settings) state.settings = {...state.settings,...d.settings};
    syncSettingsUI();
  } catch(e){}
}

function syncSettingsUI(){
  const s = state.settings;
  document.getElementById('s-rate').value = s.hourlyRate;
  document.getElementById('s-ot-mult').value = s.otMult;
  document.getElementById('s-ot-hrs').value = s.otAfter;
  document.getElementById('s-freq').value = s.payFreq;
  document.getElementById('s-filing').value = s.filing;
  document.getElementById('s-state').value = s.stateTax;
  document.getElementById('s-opt').value = s.denverOPT;
}

function saveSettings(){
  state.settings.hourlyRate = parseFloat(document.getElementById('s-rate').value)||18;
  state.settings.otMult = parseFloat(document.getElementById('s-ot-mult').value)||1.5;
  state.settings.otAfter = parseFloat(document.getElementById('s-ot-hrs').value)||40;
  state.settings.payFreq = document.getElementById('s-freq').value;
  state.settings.filing = document.getElementById('s-filing').value;
  state.settings.stateTax = parseFloat(document.getElementById('s-state').value)||4.40;
  state.settings.denverOPT = parseFloat(document.getElementById('s-opt').value)||5.75;
  save(); render();
}

function clearAll(){
  if(confirm('Clear all shift data?')){ state.sessions=[]; state.clockInTime=null; save(); render(); }
}

// ─── TABS ─────────────────────────────────────────────────────────────
let currentTab = 'dashboard';
function setTab(t){
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+t).classList.add('active');
  document.getElementById('nav-'+t).classList.add('active');
  currentTab = t;
}

// ─── CLOCK ────────────────────────────────────────────────────────────
let timerInterval = null;
function toggleClock(){
  if(!state.clockInTime){
    state.clockInTime = new Date();
    timerInterval = setInterval(render, 1000);
  } else {
    const end = new Date();
    const hrs = (end - state.clockInTime) / 3600000;
    state.sessions.push({id:Date.now(), date:state.clockInTime, start:state.clockInTime, end, hours:+hrs.toFixed(4), note:''});
    state.clockInTime = null;
    clearInterval(timerInterval);
    save();
  }
  render();
}

function addManual(){
  const date = document.getElementById('m-date').value;
  const s = document.getElementById('m-start').value;
  const e = document.getElementById('m-end').value;
  const note = document.getElementById('m-note').value;
  document.getElementById('manual-error').textContent='';
  if(!date||!s||!e){document.getElementById('manual-error').textContent='Fill in date, start & end time.';return;}
  const start = new Date(date+'T'+s), end = new Date(date+'T'+e);
  if(isNaN(start)||isNaN(end)||end<=start){document.getElementById('manual-error').textContent='End must be after start.';return;}
  const hrs = (end-start)/3600000;
  state.sessions.push({id:Date.now(),date:start,start,end,hours:+hrs.toFixed(4),note});
  document.getElementById('m-date').value='';
  document.getElementById('m-start').value='';
  document.getElementById('m-end').value='';
  document.getElementById('m-note').value='';
  save(); render();
  setTab('sessions');
}

function deleteSession(id){
  state.sessions = state.sessions.filter(s=>s.id!==id);
  save(); render();
}

// ─── TAX CALC ─────────────────────────────────────────────────────────
const BRACKETS = {
  single:[[0,11600,.10],[11600,47150,.12],[47150,100525,.22],[100525,191950,.24],[191950,243725,.32],[243725,609350,.35],[609350,Infinity,.37]],
  married:[[0,23200,.10],[23200,94300,.12],[94300,201050,.22],[201050,383900,.24],[383900,487450,.32],[487450,731200,.35],[731200,Infinity,.37]]
};
function fedTax(annual, status){
  const bs = BRACKETS[status]||BRACKETS.single;
  let t=0;
  for(const [min,max,rate] of bs){ if(annual<=min)break; t+=(Math.min(annual,max)-min)*rate; }
  return t;
}

// ─── FORMAT ───────────────────────────────────────────────────────────
const fmt$ = n => '$'+n.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});
const fmtT = d => d.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
const fmtD = d => d.toLocaleDateString([],{month:'short',day:'numeric'});

function elapsedStr(ms){
  const s=Math.floor(ms/1000), h=Math.floor(s/3600), m=Math.floor((s%3600)/60), sec=s%60;
  return String(h).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(sec).padStart(2,'0');
}

// ─── COMPUTE ──────────────────────────────────────────────────────────
function compute(){
  const {hourlyRate,otMult,otAfter,payFreq,filing,stateTax,denverOPT} = state.settings;
  const now = new Date();
  const weekStart = new Date(now); weekStart.setHours(0,0,0,0); weekStart.setDate(now.getDate()-now.getDay());
  const weekSess = state.sessions.filter(s=>s.date>=weekStart);
  const weekHrs = weekSess.reduce((a,s)=>a+s.hours,0);
  const regHrs = Math.min(weekHrs,otAfter), otHrs = Math.max(0,weekHrs-otAfter);
  const grossWeek = regHrs*hourlyRate + otHrs*hourlyRate*otMult;

  const annWeek = grossWeek*52;
  const fedT = fedTax(annWeek,filing);
  const ficaT = annWeek*0.0765;
  const stateT = annWeek*(stateTax/100);
  const optAnnual = denverOPT*12;
  const totalTaxAnn = fedT+ficaT+stateT+optAnnual;
  const effRate = annWeek>0 ? totalTaxAnn/annWeek*100 : 0;
  const taxWeek = totalTaxAnn/52;
  const netWeek = grossWeek - taxWeek;

  const wpp = {weekly:1,biweekly:2,semimonthly:2.167,monthly:4.333}[payFreq]||2;
  const ppGross = grossWeek*wpp, ppTax = taxWeek*wpp, ppNet = netWeek*wpp;

  const elapsed = state.clockInTime ? Date.now()-state.clockInTime.getTime() : 0;
  const liveEarning = elapsed>0 ? (elapsed/3600000)*hourlyRate : 0;

  return {weekHrs,weekSess,grossWeek,otHrs,otHrs,regHrs,otHrs,effRate,taxWeek,netWeek,ppGross,ppTax,ppNet,annWeek,fedT,ficaT,stateT,optAnnual,totalTaxAnn,elapsed,liveEarning,wpp,payFreq,hourlyRate};
}

// ─── RENDER ───────────────────────────────────────────────────────────
function render(){
  const now = new Date();
  document.getElementById('live-clock').textContent = fmtT(now)+':'+String(now.getSeconds()).padStart(2,'0');
  document.getElementById('live-date').textContent = fmtD(now)+', '+now.getFullYear();

  const c = compute();
  const ci = !!state.clockInTime;

  // Dashboard
  document.getElementById('d-week-hrs').textContent = c.weekHrs.toFixed(1)+'h';
  document.getElementById('d-week-sess').textContent = c.weekSess.length+' shift'+(c.weekSess.length!==1?'s':'');
  document.getElementById('d-gross').textContent = fmt$(c.grossWeek);
  document.getElementById('d-rate').textContent = '@$'+state.settings.hourlyRate+'/hr';
  document.getElementById('d-net').textContent = fmt$(c.netWeek);
  document.getElementById('d-eff-rate').textContent = '~'+c.effRate.toFixed(1)+'% tax';
  document.getElementById('d-pp-gross').textContent = fmt$(c.ppGross);
  document.getElementById('d-pp-tax').textContent = '-'+fmt$(c.ppTax);
  document.getElementById('d-pp-net').textContent = fmt$(c.ppNet);

  // Clocked-in banner
  const cb = document.getElementById('clocked-in-banner');
  if(ci){ cb.style.display='flex'; document.getElementById('banner-since').textContent='Since '+fmtT(state.clockInTime); document.getElementById('banner-timer').textContent=elapsedStr(c.elapsed); }
  else cb.style.display='none';

  // OT banner
  const ot = document.getElementById('ot-banner');
  if(c.otHrs>0){ ot.style.display='flex'; document.getElementById('ot-detail').textContent=c.otHrs.toFixed(1)+'h OT @ $'+(state.settings.hourlyRate*state.settings.otMult).toFixed(2)+'/hr'; }
  else ot.style.display='none';

  // Clock buttons
  const btnClass = ci ? 'clock-btn out' : 'clock-btn in';
  const btnTxt = ci ? '⏹ Clock Out' : '▶ Clock In';
  document.getElementById('dash-clock-btn').className = btnClass;
  document.getElementById('dash-clock-btn').textContent = btnTxt;
  document.getElementById('main-clock-btn').className = btnClass;
  document.getElementById('main-clock-btn').textContent = btnTxt;

  // Timer
  document.getElementById('timer-display').textContent = ci ? elapsedStr(c.elapsed) : '00:00:00';
  document.getElementById('timer-display').style.color = ci ? 'var(--green)' : 'var(--accent)';
  document.getElementById('timer-status').textContent = ci ? 'Started at '+fmtT(state.clockInTime)+' · '+fmtD(state.clockInTime) : 'Press to start tracking';
  const earnTxt = ci ? 'Est. so far: '+fmt$(c.liveEarning) : '';
  document.getElementById('clock-earning').textContent = earnTxt;
  document.getElementById('dash-earning').textContent = earnTxt;

  // Sessions
  const sl = document.getElementById('sess-list');
  document.getElementById('sess-count-title').textContent = 'All Shifts ('+state.sessions.length+')';
  if(state.sessions.length===0){ sl.innerHTML='<div class="empty">No shifts yet. Clock in or add manually.</div>'; }
  else {
    sl.innerHTML = [...state.sessions].reverse().map(s=>`
      <div class="sess-row">
        <div>
          <div class="sess-info">${fmtD(s.date)}</div>
          <div class="sess-sub">${fmtT(s.start)} → ${fmtT(s.end)}${s.note?' · '+s.note:''}</div>
        </div>
        <div class="sess-right">
          <span class="pill accent">${s.hours.toFixed(2)}h</span>
          <span class="pill green">${fmt$(s.hours*state.settings.hourlyRate)}</span>
          <button class="btn-sm" onclick="deleteSession(${s.id})">✕</button>
        </div>
      </div>`).join('');
  }

  // Taxes
  const taxes = [
    {label:'Federal Income Tax', amount:c.fedT/52, rate:c.fedT/Math.max(c.annWeek,1)*100, color:'var(--red)'},
    {label:'FICA (SS + Medicare)', amount:c.ficaT/52, rate:7.65, color:'#f09050'},
    {label:'Colorado State (4.40%)', amount:c.stateT/52, rate:state.settings.stateTax, color:'#a060f0'},
    {label:'Denver OPT ($5.75/mo)', amount:state.settings.denverOPT/4.33, rate:state.settings.denverOPT/Math.max(c.grossWeek,1)*100, color:'var(--blue)'},
  ];
  document.getElementById('tax-rows').innerHTML = taxes.map(t=>`
    <div style="margin-bottom:14px">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:5px">
        <span style="font-size:12px">${t.label}</span>
        <div style="display:flex;gap:8px;align-items:center">
          <span class="pill" style="background:${t.color}22;color:${t.color}">${t.rate.toFixed(2)}%</span>
          <span style="font-family:'DM Mono',monospace;font-weight:500;font-size:13px;color:${t.color}">${fmt$(t.amount)}</span>
        </div>
      </div>
      <div class="bar-bg"><div class="bar-fill" style="width:${Math.min(t.rate,40)/40*100}%;background:${t.color}"></div></div>
    </div>`).join('');
  document.getElementById('eff-rate-display').textContent = c.effRate.toFixed(1)+'%';
  document.getElementById('t-gross').textContent = fmt$(c.grossWeek);
  document.getElementById('t-tax').textContent = '-'+fmt$(c.taxWeek);
  document.getElementById('t-net').textContent = fmt$(c.netWeek);
  document.getElementById('pp-label').textContent = 'Per Paycheck ('+c.payFreq+')';
  document.getElementById('t-pp-gross').textContent = fmt$(c.ppGross);
  document.getElementById('t-pp-tax').textContent = '-'+fmt$(c.ppTax);
  document.getElementById('t-pp-net').textContent = fmt$(c.ppNet);
}

// ─── INIT ─────────────────────────────────────────────────────────────
load();
render();
setInterval(render, 1000);
</script>

</body>
</html>